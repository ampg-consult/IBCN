rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {    
    
    // 🟢 GLOBAL HELPERS
    function isSignedIn() { return request.auth != null; }    
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    
    // Safely check role (returns false if user doc doesn't exist)
    function hasRole(role) {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return isSignedIn() && exists(userPath) && get(userPath).data.role == role;
    }

    // 👤 USERS COLLECTION
    match /users/{uid} {
      allow read: if isSignedIn();
      
      // CREATE: Ensure UID matches AND the username lock is being created for this user
      allow create: if isSignedIn() 
                    && request.auth.uid == uid 
                    && getAfter(/databases/$(database)/documents/usernames/$(request.resource.data.username_lower)).data.owner == uid;

      allow update: if isSignedIn() && (request.auth.uid == uid || hasRole('admin'));
      
      // Sub-collections (Progress, Vault, Alerts)
      match /progress/{id} { allow read, write: if request.auth.uid == uid; }
      match /study_vault/{id} { allow read, write: if request.auth.uid == uid; }
      match /career_alerts/{id} { allow read: if request.auth.uid == uid; allow write: if hasRole('admin'); }
    }

    // 🆔 USERNAMES COLLECTION (Uniqueness Tracker)
    match /usernames/{username} {
      allow read: if true; 
      // ONLY allow creation if the username document DOES NOT exist (Enforces Uniqueness)
      allow create: if isSignedIn() && !exists(/databases/$(database)/documents/usernames/$(username));
      allow delete: if hasRole('admin');
    }

    // 👤 USER PUBLIC (Searchable Profiles)
    match /user_public/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
    }

    // 🤖 AI BUILDER REPORTS
    match /ai_reports/{reportId} {
      allow read, delete, update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    // 🛒 MARKETPLACE & MONETIZATION
    match /marketplace_assets/{assetId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.authorUid == request.auth.uid || hasRole('admin'));
    }

    match /orders/{orderId} {
      allow read: if isSignedIn() && (resource.data.buyerId == request.auth.uid || resource.data.sellerId == request.auth.uid || hasRole('admin'));
      allow create: if isSignedIn(); // In prod, verify amount via cloud function
    }

    match /user_reputation/{uid} {
      allow read: if true;
      allow write: if hasRole('admin'); // System only
    }

    // 💳 WALLETS & PAYMENTS
    match /wallets/{uid} {
      allow read: if isOwner(uid) || hasRole('admin');
      allow write: if hasRole('admin'); // System only via cloud functions
    }

    match /wallet_transactions/{txId} {
      allow read: if isSignedIn() && (resource.data.uid == request.auth.uid || hasRole('admin'));
    }

    match /payouts/{payoutId} {
      allow read: if isSignedIn() && (resource.data.uid == request.auth.uid || hasRole('admin'));
      allow create: if isSignedIn();
      allow update: if hasRole('admin');
    }

    // 🤝 COLLABORATION SYSTEM
    match /projects/{projectId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.ownerUid == request.auth.uid || hasRole('admin'));
    }

    match /project_members/{memberId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // Logic check: isOwner of project
    }

    match /project_invites/{inviteId} {
      allow read: if isSignedIn() && (resource.data.invitedUserId == request.auth.uid || resource.data.senderId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.invitedUserId == request.auth.uid;
    }

    match /project_messages/{msgId} {
      allow read: if isSignedIn(); // Add membership check in prod
      allow create: if isSignedIn();
    }

    match /project_activity/{actId} {
      allow read: if isSignedIn();
      allow create: if false; // System only
    }

    // 💰 BOUNTIES
    match /bounties/{bountyId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
    }

    // 💼 JOBS PORTAL
    match /jobs/{jobId} {
      allow read: if true;
      allow create: if isSignedIn() && (hasRole('employer') || hasRole('admin'));
      allow update, delete: if isSignedIn() && (resource.data.employerId == request.auth.uid || hasRole('admin'));
    }

    // 📝 APPLICATIONS
    match /applications/{appId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.talentId || 
        request.auth.uid == resource.data.employerId || 
        hasRole('admin')
      );
    }

    // 📚 COURSE METADATA
    match /courses/{courseId} {
      allow read: if isSignedIn();
      allow write: if hasRole('admin');
      match /lessons/{lessonId} {
        allow read: if isSignedIn();
        allow write: if hasRole('admin');
      }
    }

    // 👣 SOCIAL
    match /followers/{followId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.followerId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.followerId == request.auth.uid;
    }
  }
}
